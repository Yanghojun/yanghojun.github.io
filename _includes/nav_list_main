<!--전체 글 수를 세기 위한 연산. sum 변수에 전체 글 수 저장-->

{% assign sum = site.posts | size %}

<nav class="nav__list">
  <input id="ac-toc" name="accordion-toc" type="checkbox" />
  <label for="ac-toc">{{ site.data.ui-text[site.locale].menu_label }}</label>
  <ul class="nav__items" id="category_tag_menu">
      <!--전체 글 수-->
      <li>
            📂 <span style="font-family:'Cafe24Oneprettynight';">전체 글 수</style> <span style="font-family:'Coming Soon';">{{sum}}</style> <span style="font-family:'Cafe24Oneprettynight';">개</style> 
      </li>
      <li>
        <!--span 태그로 카테고리들을 크게 분류 ex) 객체지향 프로그래밍 / Coding test -->
        <span class="nav__sub-title">컴퓨터 전공</span>
            <!--ul 태그로 같은 카테고리들 모아둔 페이지들 나열-->
            <ul>
                <!--Cpp 카테고리 글들을 모아둔 페이지인 /categories/cpp 주소의 글로 링크 연결-->
                <!--category[1].size 로 해당 카테고리를 가진 글의 개수 표시--> 
                {% for category in site.categories %}
                    {% if category[0] == "객체지향 프로그래밍" %}
                        <li><a href="/categories/객체지향 프로그래밍" class="">객체지향 프로그래밍 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "자료구조" %}
                        <li><a href="/categories/자료구조" class="">자료구조 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "깃허브" %}
                        <li><a href="/categories/깃허브" class="">깃허브 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "코딩테스트" %}
                        <li><a href="/categories/코딩테스트" class="">코딩테스트 ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
        <span class="nav__sub-title">머신러닝</span>
            <ul>
                {% for category in site.categories %}
                    {% if category[0] == "지도 학습" %}
                        <li><a href="/categories/지도 학습" class="">지도 학습({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}

                {% for category in site.categories %}
                    {% if category[0] == "비지도 학습" %}
                        <li><a href="/categories/비지도 학습" class="">비지도 학습({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}

                {% for category in site.categories %}
                    {% if category[0] == "시각화" %}
                        <li><a href="/categories/시각화" class=""> 시각화 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "Pandas" %}
                        <li><a href="/categories/Pandas" class=""> Pandas ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "Numpy" %}
                        <li><a href="/categories/Numpy" class=""> Numpy ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}

                {% for category in site.categories %}
                    {% if category[0] == "자연어 처리" %}
                        <li><a href="/categories/자연어 처리" class="">자연어 처리({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "영상처리" %}
                        <li><a href="/categories/영상처리" class=""> 영상처리 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "추천시스템" %}
                        <li><a href="/categories/추천시스템" class=""> 추천시스템 ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}

                {% for category in site.categories %}
                    {% if category[0] == "Paper-Review" %}
                        <li><a href="/categories/Paper-Review" class="">Paper-Review ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "평가" %}
                        <li><a href="/categories/평가" class="">평가 ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "사이킷런(Scikit-learn)" %}
                        <li><a href="/categories/사이킷런(Scikit-learn)" class="">사이킷런(Scikit-learn) ({{category[1].size}})</a></li>
                    {% endif %}
                    {% if category[0] == "캐글 대회 문제" %}
                        <li><a href="/categories/캐글 대회 문제" class="">캐글 대회 문제 ({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
         <span class="nav__sub-title">인공지능 이해를 위한 수학</span>
            <ul>
                {% for category in site.categories %}
                    {% if category[0] == "기초수학" %}
                        <li><a href="/categories/기초수학" class="">기초수학({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
                {% for category in site.categories %}
                    {% if category[0] == "선형대수학" %}
                        <li><a href="/categories/선형대수학" class="">선형대수학({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "통계학" %}
                        <li><a href="/categories/통계학" class="">통계학({{category[1].size}})</a></li>
                    {% endif %}
                    
                {% endfor %}
            </ul>
        
        <span class="nav__sub-title">딥러닝</span>
            <ul>
                {% for category in site.categories %}
                    {% if category[0] == "기초 지식" %}
                        <li><a href="/categories/기초 지식" class="">기초 지식({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "대표 모델 정리" %}
                        <li><a href="/categories/대표 모델 정리" class="">대표 모델 정리({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "Pytorch" %}
                        <li><a href="/categories/Pytorch" class="">Pytorch({{category[1].size}})</a></li>
                    {% endif %}

                {% endfor %}
            </ul>

        <span class="nav__sub-title">Computer Language</span>
            <ul>
                {% for category in site.categories %}
                    {% if category[0] == "Kotlin" %}
                        <li><a href="/categories/Kotlin" class="">Kotlin({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "Java" %}
                        <li><a href="/categories/Java" class="">Java({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "Python" %}
                        <li><a href="/categories/Python" class="">Python({{category[1].size}})</a></li>
                    {% endif %}

                    {% if category[0] == "C++" %}
                        <li><a href="/categories/C++" class="">C++({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>

        <span class="nav__sub-title">FrontEnd</span>
            <ul>
                {% for category in site.categories %}
                    {% if category[0] == "안드로이드" %}
                        <li><a href="/categories/안드로이드" class="">안드로이드({{category[1].size}})</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
      </li>
  </ul>
</nav>